# Copy to .env for local development (never commit .env).

# Long random string — required in production for secure admin sessions.
SESSION_SECRET=

# Used only when data/admin.json does not exist yet. In production, set a strong
# password here for the first bootstrap, then change it under /admin/settings.
ADMIN_INITIAL_PASSWORD=

# Neon PostgreSQL connection string (pooled URL recommended for serverless).
# When set: CMS JSON is stored in table cms_documents; sessions use table session.
# Run: node scripts/seed-cms-to-neon.js  (once) to copy data/*.json into Neon.
DATABASE_URL=postgresql://neondb_owner:npg_fETWi4mr7AzS@ep-fragrant-silence-abixp0ea-pooler.eu-west-2.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# Optional: max connections for the shared pg Pool (default 5).
# PG_POOL_MAX=5

# One-off: set new admin password (local or Neon if DATABASE_URL is set). Min 12 characters.
# ADMIN_NEW_PASSWORD=
# ADMIN_USERNAME=admin
