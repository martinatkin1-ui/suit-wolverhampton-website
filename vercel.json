{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build:static",
  "functions": {
    "api/index.js": {
      "maxDuration": 60,
      "includeFiles": "{views/**,data/**,public/**,scripts/**}"
    }
  },
  "rewrites": [{ "source": "/:path*", "destination": "/api/:path*" }]
}
