<!DOCTYPE html>
<html lang="en-GB">
<head>
 <!-- SUIT build: outreach + news-more nav fallback2026-04 — view-source to confirm you are on this app -->
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <% var _base = (typeof siteUrl !== 'undefined' && siteUrl) ? siteUrl : 'https://www.suitrecoverywolverhampton.com';
  var _noIndex = typeof noIndex !== 'undefined' && noIndex;
  var _path = (typeof pageCanonical === 'string' && pageCanonical.length) ? pageCanonical : '/';
  var _fullUrl = _base + (_noIndex ? '/' : _path);
  var _ogUrl = _noIndex ? (_base + '/') : _fullUrl;
  var _desc = (typeof pageDescription !== 'undefined' && pageDescription) ? pageDescription : 'SUIT Wolverhampton — Free, confidential peer-led addiction and alcohol recovery support. Lived experience mentoring, advocacy, SMART Recovery, harm reduction, creative arts, and community programmes. Est. 2007. WVCA project.';
  var _kw = (typeof pageKeywords !== 'undefined' && pageKeywords) ? pageKeywords : ((typeof defaultSeoKeywords !== 'undefined' && defaultSeoKeywords) ? defaultSeoKeywords : 'addiction recovery Wolverhampton, alcohol support, drug help West Midlands, SUIT');
  var _ogTitle = (typeof pageTitle !== 'undefined' && pageTitle) ? (pageTitle + ' | SUIT Wolverhampton') : 'SUIT Wolverhampton — Addiction & alcohol recovery (peer support)'; %>
  <meta name="description" content="<%= _desc %>">
  <meta name="keywords" content="<%= _kw %>">
  <% if (_noIndex) { %><meta name="robots" content="noindex, follow"><% } %>
  <% if (!_noIndex) { %><link rel="canonical" href="<%= _fullUrl %>"><% } %>
  <link rel="alternate" type="application/rss+xml" title="SUIT Wolverhampton — Stories & Updates" href="<%= _base %>/feed.xml">
  <meta name="theme-color" content="#0D1117">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <meta name="geo.region" content="GB-WLV">
  <meta name="geo.placename" content="Wolverhampton">

  <!-- Open Graph / Social Sharing -->
  <meta property="og:type" content="website">
  <meta property="og:locale" content="en_GB">
  <meta property="og:site_name" content="SUIT Wolverhampton">
  <meta property="og:title" content="<%= _ogTitle %>">
  <meta property="og:description" content="<%= _desc %>">
  <meta property="og:url" content="<%= _ogUrl %>">
  <meta property="og:image" content="<%= _base %>/images/suit-logo.webp">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:site" content="@SUITeam">
  <meta name="twitter:title" content="<%= _ogTitle %>">
  <meta name="twitter:description" content="<%= _desc %>">
  <meta name="twitter:image" content="<%= _base %>/images/suit-logo.webp">

  <!-- Structured Data: organisation + website (helps search + AI entity understanding) --><%
  var _schema = {
    '@context': 'https://schema.org',
    '@graph': [
      {
        '@type': 'NonprofitOrganization',
        '@id': _base + '/#organization',
        'name': 'SUIT — Service User Involvement Team',
        'alternateName': ['SUIT Wolverhampton', 'Service User Involvement Team'],
        'description': "Wolverhampton's Lived Experience Recovery Organisation (LERO): peer-led wraparound support for people affected by drug and alcohol use, and their families. Free, confidential help — mentoring, advocacy, groups, harm reduction, and cultural outreach. A WVCA project.",
        'url': _base,
        'logo': _base + '/images/suit-logo.webp',
        'image': _base + '/images/suit-logo.webp',
        'foundingDate': '2007-02',
        'telephone': '+441902328983',
        'email': 'suit@wvca.org.uk',
        'knowsAbout': [
          'Addiction recovery',
          'Alcohol use recovery',
          'Substance use disorders',
          'Harm reduction',
          'Peer mentoring',
          'Lived experience recovery',
          'SMART Recovery',
          'Mental health and addiction',
          'Family support and affected others'
        ],
        'address': {
          '@type': 'PostalAddress',
          'streetAddress': 'Paycare House, George Street',
          'addressLocality': 'Wolverhampton',
          'addressRegion': 'West Midlands',
          'postalCode': 'WV2 4DX',
          'addressCountry': 'GB'
        },
        'areaServed': { '@type': 'City', 'name': 'Wolverhampton', 'containedInPlace': { '@type': 'AdministrativeArea', 'name': 'West Midlands' } },
        'parentOrganization': { '@type': 'Organization', 'name': 'WVCA — Wolverhampton Voluntary & Community Action', 'url': 'https://www.wvca.org.uk/' },
        'award': [
          "Queen's Award for Voluntary Services 2014",
          'European Model of Good Practice — Street Support Project EU 2019',
          'BeTrAd EU Recognition 2018'
        ],
        'sameAs': [
          'https://facebook.com/SUITWolves',
          'https://instagram.com/suit_services/',
          'https://twitter.com/SUITeam',
          'https://www.youtube.com/@ServiceUserInvolvementTeam'
        ],
        'contactPoint': [
          {
            '@type': 'ContactPoint',
            'telephone': '+44-1902-328983',
            'email': 'suit@wvca.org.uk',
            'contactType': 'helpline',
            'areaServed': 'GB',
            'availableLanguage': ['en-GB']
          }
        ]
      },
      {
        '@type': 'WebSite',
        '@id': _base + '/#website',
        'url': _base,
        'name': 'SUIT Wolverhampton — Lived Experience Recovery',
        'description': _desc,
        'inLanguage': 'en-GB',
        'publisher': { '@id': _base + '/#organization' },
        'about': { '@id': _base + '/#organization' }
      },
      {
        '@type': 'ItemList',
        '@id': _base + '/#primary-entry-points',
        'name': 'Primary SUIT service and information pages',
        'itemListElement': [
          { '@type': 'ListItem', 'position': 1, 'name': 'Get help now', 'item': _base + '/get-help' },
          { '@type': 'ListItem', 'position': 2, 'name': 'How we help (services)', 'item': _base + '/services' },
          { '@type': 'ListItem', 'position': 3, 'name': 'Weekly timetable', 'item': _base + '/timetable' },
          { '@type': 'ListItem', 'position': 4, 'name': 'In the community', 'item': _base + '/community' },
          { '@type': 'ListItem', 'position': 5, 'name': 'Cultural outreach', 'item': _base + '/community/outreach' },
          { '@type': 'ListItem', 'position': 6, 'name': 'Announcements', 'item': _base + '/news-more/announcements' },
          { '@type': 'ListItem', 'position': 7, 'name': 'Contact', 'item': _base + '/contact' }
        ]
      }
    ]
  }; %><script type="application/ld+json"><%- JSON.stringify(_schema) %></script>
  <% if (typeof faqStructuredData !== 'undefined' && faqStructuredData) { %><script type="application/ld+json"><%- JSON.stringify(faqStructuredData) %></script><% } %>
  <title><%= typeof pageTitle !== 'undefined' && pageTitle ? pageTitle + ' | ' : '' %>SUIT Wolverhampton — Lived Experience Recovery</title>
  <link rel="manifest" href="/manifest.json">
  <link rel="icon" type="image/png" href="/images/favicon.png">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Outfit:wght@400;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <%- include('partials/iconify') %>
</head>
<body>

  <!-- Skip to content (accessibility) -->
  <a href="#main-content" class="skip-link">Skip to main content</a>

  <%- include('partials/a11y-bar') %>
  <%- include('partials/header') %>

  <main id="main-content">
    <%- body -%>
  </main>

  <%- include('partials/footer') %>
  <%- include('partials/floating-buttons') %>
  <%- include('partials/ai-bubble') %>

  <!-- Cookie Consent -->
  <div id="cookieConsent" class="cookie-consent" style="display:none;">
    <p>We use essential cookies to make this website work. No tracking, no ads.</p>
    <button onclick="acceptCookies()" class="btn btn-primary" style="padding: 0.5rem 1.5rem; font-size: 0.85rem;">Accept</button>
  </div>

  <script src="/js/main.js"></script>
  <script>
    if ('serviceWorker' in navigator) {
      navigator.serviceWorker.register('/sw.js').catch(() => {});
    }
  </script>
</body>
</html>
