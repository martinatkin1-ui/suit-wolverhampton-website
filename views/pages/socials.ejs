</section>

<!-- Unified Feed -->
<section class="section">
  <div class="section-header">
    <h2>Latest Updates</h2>
    <p>Stories, community posts, and milestones — all in one feed.</p>
  </div>

  <!-- Feed Filter -->
  <div class="feed-filter-bar">
    <button class="feed-filter-btn active" data-filter="all">All Updates</button>
    <button class="feed-filter-btn" data-filter="story">Stories of Hope</button>
    <button class="feed-filter-btn" data-filter="community">Community</button>
  </div>

  <div class="socials-feed">
    <% feedItems.forEach(function(item, index) { %>
    <article class="socials-feed-item" data-type="<%= item.type %>">
      <div class="socials-feed-meta">
        <span class="socials-feed-badge socials-badge-<%= item.type %>">
          <% if (item.type === 'story') { %><span style="display:inline-flex;align-items:center;gap:0.35rem;"><%- include('partials/icon', { name: 'lucide:heart', size: 16 }) %> Story of Hope</span><% } else { %><span style="display:inline-flex;align-items:center;gap:0.35rem;"><%- include('partials/icon', { name: 'lucide:globe', size: 16 }) %> Community</span><% } %>
        </span>
        <time datetime="<%= item.date %>"><%= new Date(item.date).toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' }) %></time>
      </div>
      <h3 class="socials-feed-title">
        <% if (item.link) { %>
          <a href="<%= item.link %>"><%= item.title %></a>
        <% } else { %>
          <%= item.title %>
        <% } %>
      </h3>
      <p class="socials-feed-excerpt"><%= item.excerpt %></p>
      <% if (item.imageUrl) { %>
        <div class="socials-feed-media">
          <img src="<%= item.imageUrl %>" alt="<%= item.title %>" loading="lazy">
        </div>
      <% } %>
      <% if (item.videoUrl) { %>
        <div class="socials-feed-video">
          <% var ytId = item.videoUrl.match(/(?:youtu\.be\/|youtube\.com\/(?:watch\?v=|embed\/))([a-zA-Z0-9_-]{11})/); %>
          <% if (ytId) { %>
            <iframe src="https://www.youtube.com/embed/<%= ytId[1] %>" title="<%= item.title %>" frameborder="0" allowfullscreen loading="lazy"></iframe>
          <% } %>
        </div>
      <% } %>
      <% if (item.tags && item.tags.length) { %>
        <div class="socials-feed-tags">
          <% item.tags.forEach(function(tag) { %>
            <span class="socials-tag">#<%= tag %></span>
          <% }); %>
        </div>
      <% } %>
      <% if (item.link) { %>
        <a href="<%= item.link %>" class="socials-read-more">Read full story →</a>
      <% } %>
    </article>
    <% }); %>
  </div>

  <% if (feedItems.length === 0) { %>
  <div class="text-center" style="padding: 3rem;">
    <p style="color: var(--text-mid); font-size: 1.1rem;">No updates yet. Check back soon!</p>
  </div>
  <% } %>
</section>

<!-- YouTube Embed Showcase -->
<section class="section section-alt">
  <div class="section-header">
    <h2>Featured Videos</h2>
    <p>Watch SUIT in action — from performances and events to powerful recovery shares.</p>
  </div>
  <div class="video-showcase-grid">
    <div class="video-showcase-item">
      <iframe src="https://www.youtube.com/embed/xF78h4LGCYY" title="SUIT - What We Do" frameborder="0" allowfullscreen loading="lazy"></iframe>
      <h4>What SUIT Does</h4>
    </div>
    <div class="video-showcase-item">
      <iframe src="https://www.youtube.com/embed/M8p_RoI3SIQ" title="Recovery Through Art & Drama" frameborder="0" allowfullscreen loading="lazy"></iframe>
      <h4>Recovery Through Art & Drama</h4>
    </div>
    <div class="video-showcase-item">
      <iframe src="https://www.youtube.com/embed/KdXSN3fD9vI" title="SUIT Day Hab" frameborder="0" allowfullscreen loading="lazy"></iframe>
      <h4>Day Hab Activities</h4>
    </div>
  </div>
  <div class="text-center" style="margin-top: 1.5rem;">
    <a href="https://www.youtube.com/@ServiceUserInvolvementTeam" target="_blank" rel="noopener" class="btn btn-outline">View All Videos on YouTube →</a>
  </div>
</section>

<!-- Share / CTA -->
<section class="section">
  <div class="referral-banner">
    <h2 style="display:flex;align-items:center;justify-content:center;gap:0.5rem;flex-wrap:wrap;"><%- include('partials/icon', { name: 'lucide:rss', size: 28 }) %> Stay in the Loop</h2>
    <p style="font-size: 1.1rem; max-width: 650px; margin: 0 auto 1.5rem;">
      Subscribe to our RSS feed and follow us on social media to see every milestone, every creative project, and every story of hope.
    </p>
    <div style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;">
      <a href="/feed.xml" class="btn btn-cta" target="_blank" rel="noopener" style="display:inline-flex;align-items:center;gap:0.4rem;"><%- include('partials/icon', { name: 'lucide:rss', size: 20 }) %> Subscribe RSS</a>
      <a href="/community" class="btn btn-outline">Explore Community →</a>
      <a href="/stories" class="btn btn-outline">Read Stories →</a>
    </div>
  </div>
</section>

<script>
// Feed filter
document.querySelectorAll('.feed-filter-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('.feed-filter-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    const filter = btn.dataset.filter;
    document.querySelectorAll('.socials-feed-item').forEach(item => {
      if (filter === 'all' || item.dataset.type === filter) {
        item.style.display = '';
      } else {
        item.style.display = 'none';
      }
    });
  });
});
</script>
