<% layout('layout') -%>

<section class="hero" style="min-height: 35vh; padding: 4rem 5%;">
  <h1>Follow <em>SUIT</em></h1>
  <p class="hero-sub">All our latest stories, updates, and social media — in one place. Stay connected without leaving the site.</p>
</section>

<!-- RSS Feed Banner -->
<section class="section">
  <div class="rss-subscribe-banner">
    <div class="rss-icon">
      <svg viewBox="0 0 24 24" width="48" height="48" fill="var(--brand-orange)">
        <circle cx="6.18" cy="17.82" r="2.18"/>
