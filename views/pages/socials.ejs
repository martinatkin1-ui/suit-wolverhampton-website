      </div>
      <div class="social-channel-info">
        <h4>Facebook</h4>
        <p>@SUITWolves</p>
        <span class="social-channel-action">Follow on Facebook →</span>
      </div>
    </a>
    <a href="https://www.instagram.com/suit_services/" target="_blank" rel="noopener" class="social-channel-card social-instagram">
      <div class="social-channel-icon">
        <svg viewBox="0 0 24 24" width="40" height="40" fill="#fff"><path d="M7.8 2h8.4C19.4 2 22 4.6 22 7.8v8.4a5.8 5.8 0 0 1-5.8 5.8H7.8C4.6 22 2 19.4 2 16.2V7.8A5.8 5.8 0 0 1 7.8 2m-.2 2A3.6 3.6 0 0 0 4 7.6v8.8C4 18.39 5.61 20 7.6 20h8.8a3.6 3.6 0 0 0 3.6-3.6V7.6C20 5.61 18.39 4 16.4 4H7.6m9.65 1.5a1.25 1.25 0 0 1 1.25 1.25A1.25 1.25 0 0 1 17.25 8 1.25 1.25 0 0 1 16 6.75a1.25 1.25 0 0 1 1.25-1.25M12 7a5 5 0 0 1 5 5 5 5 0 0 1-5 5 5 5 0 0 1-5-5 5 5 0 0 1 5-5m0 2a3 3 0 0 0-3 3 3 3 0 0 0 3 3 3 3 0 0 0 3-3 3 3 0 0 0-3-3z"/></svg>
      </div>
      <div class="social-channel-info">
        <h4>Instagram</h4>
        <p>@suit_services</p>
        <span class="social-channel-action">Follow on Instagram →</span>
      </div>
    </a>
    <a href="https://twitter.com/SUITeam" target="_blank" rel="noopener" class="social-channel-card social-twitter">
      <div class="social-channel-icon">
        <svg viewBox="0 0 24 24" width="40" height="40" fill="#fff"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
      </div>
      <div class="social-channel-info">
        <h4>X (Twitter)</h4>
        <p>@SUITeam</p>
        <span class="social-channel-action">Follow on X →</span>
      </div>
    </a>
    <a href="https://www.youtube.com/@ServiceUserInvolvementTeam" target="_blank" rel="noopener" class="social-channel-card social-youtube">
      <div class="social-channel-icon">
        <svg viewBox="0 0 24 24" width="40" height="40" fill="#fff"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
