<% var noIndex = true; %>
<% layout('layout') -%>

<section class="section text-center" style="min-height: 60vh; display: flex; flex-direction: column; align-items: center; justify-content: center;">
  <div class="sunrise-icon" style="margin-bottom: 1rem;"><%- include('partials/icon', { name: 'lucide:sunrise', size: 80 }) %></div>
  <h1>Page Not Found</h1>
  <p style="font-size: 1.15rem; color: var(--text-mid); max-width: 500px; margin: 1rem auto 2rem;">
    Sorry, we couldn't find that page. But we're here to help you find what you need.
  </p>
  <div style="display: flex; gap: 1rem; flex-wrap: wrap; justify-content: center;">
    <a href="/" class="btn btn-primary">Go Home</a>
    <a href="/get-help" class="btn btn-cta">Get Help Now</a>
  </div>
</section>
