<% layout('admin/admin-layout') -%>

<% var nmPages = typeof newsMorePages !== 'undefined' && newsMorePages ? newsMorePages : []; %>
<h2><%= post ? 'Edit' : 'New' %> Community Post</h2>
<% if (typeof serverlessMediaUpload !== 'undefined' && serverlessMediaUpload) { %>
<p class="admin-hint" style="margin-bottom: var(--space-md);">On the <strong>live site</strong>, photos you upload here are stored in the database (not on disk). Video <strong>files</strong> cannot be uploaded there — use a YouTube or other link in the video URL field.</p>
<% } %>
<p class="admin-hint" style="margin-bottom: var(--space-lg);">Posts show on <a href="/community" target="_blank" rel="noopener">In the Community</a>. Tick pages below to <strong>also</strong> publish the same story on News &amp; More topic pages. You can use a <strong>file upload</strong>, a <strong>URL</strong>, or both (upload wins for that slot).</p>

<form method="POST" action="/admin/community/save" enctype="multipart/form-data" class="admin-form">
  <%- include('../partials/admin-csrf') %>
  <input type="hidden" name="postId" value="<%= post ? post.id : '' %>">

  <div class="form-row">
    <div class="form-group">
      <label for="date">Date *</label>
      <input type="date" id="date" name="date" required value="<%= post ? post.date : new Date().toISOString().split('T')[0] %>">
    </div>
    <div class="form-group">
      <label for="category">Feed category *</label>
      <select id="category" name="category" required aria-describedby="category-hint">
        <option value="art" <%= post && post.category === 'art' ? 'selected' : '' %>>Art</option>
        <option value="music" <%= post && post.category === 'music' ? 'selected' : '' %>>Music</option>
        <option value="drama" <%= post && post.category === 'drama' ? 'selected' : '' %>>Drama</option>
        <option value="events" <%= post && post.category === 'events' ? 'selected' : '' %>>Events</option>
        <option value="pride" <%= post && post.category === 'pride' ? 'selected' : '' %>>PRIDE</option>
        <option value="cultural" <%= post && post.category === 'cultural' ? 'selected' : '' %>>Cultural</option>
        <option value="announcements" <%= post && post.category === 'announcements' ? 'selected' : '' %>>Announcements</option>
      </select>
      <p id="category-hint" style="font-size: 0.8rem; color: var(--text-mid); margin-top: 0.35rem;">Used for filters on the community timeline.</p>
    </div>
    <div class="form-group">
      <label for="tags">Tags (optional)</label>
      <input type="text" id="tags" name="tags" value="<%= post && post.tags ? post.tags.join(', ') : '' %>" placeholder="e.g. exhibition, conference" aria-describedby="tags-hint">
      <p id="tags-hint" style="font-size: 0.8rem; color: var(--text-mid); margin-top: 0.35rem;">Comma-separated labels shown on the card.</p>
    </div>
  </div>

  <div class="form-group">
    <label for="title">Header (title) *</label>
    <input type="text" id="title" name="title" required value="<%= post ? post.title : '' %>" placeholder="Main headline">
  </div>

  <div class="form-group">
    <label for="subtitle">Sub-heading (optional)</label>
    <input type="text" id="subtitle" name="subtitle" value="<%= post && post.subtitle ? post.subtitle : '' %>" placeholder="Short line under the headline">
  </div>

  <div class="form-group">
    <label for="body">Main text *</label>
    <textarea id="body" name="body" rows="8" required placeholder="The main message for this post…"><%= post ? post.body : '' %></textarea>
  </div>

  <div class="form-row">
    <div class="form-group">
      <label for="link">Link (optional)</label>
      <input type="url" id="link" name="link" value="<%= post && post.link ? post.link : '' %>" placeholder="https://…">
    </div>
    <div class="form-group">
      <label for="linkText">Link label</label>
      <input type="text" id="linkText" name="linkText" value="<%= post && post.linkText ? post.linkText : '' %>" placeholder="e.g. Book a place">
    </div>
  </div>

  <div class="form-row">
    <div class="form-group">
      <label for="quote">Pull quote (optional)</label>
      <textarea id="quote" name="quote" rows="2" placeholder="Optional highlighted quote"><%= post && post.quote ? post.quote : '' %></textarea>
    </div>
    <div class="form-group">
      <label for="quoteAuthor">Quote attribution</label>
      <input type="text" id="quoteAuthor" name="quoteAuthor" value="<%= post && post.quoteAuthor ? post.quoteAuthor : '' %>" placeholder="Name or role">
    </div>
  </div>

  <div class="admin-card" style="margin: var(--space-lg) 0;">
    <h3 style="display:flex;align-items:center;gap:0.45rem;"><%- include('../partials/icon', { name: 'lucide:images', size: 22 }) %> Photo &amp; video</h3>
    <p style="color: var(--text-mid); font-size: 0.9rem; margin-bottom: var(--space-md);">Add a picture or video to the card. Use upload and/or paste a URL (from <a href="/admin/gallery">Gallery</a> or elsewhere).</p>
    <div class="form-row">
      <div class="form-group">
        <label for="postImage">Upload photo</label>
        <% if (post && post.imageUrl) { %>
          <div style="margin-bottom: 0.5rem;">
            <img src="<%= post.imageUrl %>" class="preview-image" alt="" style="max-height: 160px; object-fit: cover; border-radius: var(--radius-sm);">
            <p style="font-size: 0.8rem; color: var(--text-mid);">Current image — upload a new file or change the URL below</p>
          </div>
        <% } %>
        <input type="file" id="postImage" name="postImage" accept="image/*">
      </div>
      <div class="form-group">
        <label for="postVideo">Upload video file</label>
        <% if (post && post.videoUrl && post.videoUrl.match(/^\//)) { %>
          <p style="font-size: 0.8rem; color: var(--text-mid); margin-bottom: 0.5rem;">Current file: <code><%= post.videoUrl %></code></p>
        <% } %>
        <input type="file" id="postVideo" name="postVideo" accept="video/*">
        <p style="font-size: 0.8rem; color: var(--text-light); margin-top: 0.25rem;">MP4, WebM, or MOV. Max 100MB. Or use a YouTube link in the field below instead.</p>
      </div>
    </div>
    <div class="form-row">
      <div class="form-group">
        <label for="imageUrl">Image URL (optional)</label>
        <input type="text" id="imageUrl" name="imageUrl" value="<%= post && post.imageUrl ? post.imageUrl : '' %>" placeholder="https://… or /uploads/gallery/…">
      </div>
      <div class="form-group">
        <label for="videoUrl">Video URL (optional)</label>
        <input type="text" id="videoUrl" name="videoUrl" value="<%= post && post.videoUrl ? post.videoUrl : '' %>" placeholder="YouTube link or /uploads/…">
        <p style="font-size: 0.8rem; color: var(--text-light); margin-top: 0.25rem;">YouTube links embed. Direct video paths play in the page.</p>
      </div>
    </div>
  </div>

  <div class="admin-card" style="margin: var(--space-lg) 0;">
    <h3 style="margin-top: 0;">Where else to publish</h3>
    <p style="color: var(--text-mid); font-size: 0.9rem; margin-bottom: var(--space-md);">Tick any News &amp; More page that should show this story. “Full post” adds the text and media after that page’s fixed content. “Header image” uses this post’s photo only in that page’s top banner.</p>
    <% if (!nmPages.length) { %>
    <p style="color: var(--text-mid); font-size: 0.9rem;">No News &amp; More pages found — check <code class="nm-inline-mono">data/news-more.json</code>.</p>
    <% } else { %>
    <fieldset style="border: 1px solid var(--border-soft); border-radius: var(--radius-sm); padding: var(--space-md); margin-bottom: var(--space-md);">
      <legend style="font-weight: 600; padding: 0 0.35rem;">Full post (repeat this content on page)</legend>
      <div style="display: grid; gap: 0.5rem;">
        <% nmPages.forEach(function(p) { %>
        <label style="display: flex; align-items: flex-start; gap: 0.5rem; cursor: pointer;">
          <input type="checkbox" name="syndicateNewsMoreSlugs" value="<%= p.slug %>" <%= post && Array.isArray(post.syndicateNewsMoreSlugs) && post.syndicateNewsMoreSlugs.indexOf(p.slug) !== -1 ? 'checked' : '' %>>
          <span><%= p.title %> <span class="nm-inline-mono" style="opacity:0.85">/news-more/<%= p.slug %></span></span>
        </label>
        <% }); %>
      </div>
    </fieldset>
    <fieldset style="border: 1px solid var(--border-soft); border-radius: var(--radius-sm); padding: var(--space-md);">
      <legend style="font-weight: 600; padding: 0 0.35rem;">Page header image (this post’s photo in the hero)</legend>
      <div style="display: grid; gap: 0.5rem;">
        <% nmPages.forEach(function(p) { %>
        <label style="display: flex; align-items: flex-start; gap: 0.5rem; cursor: pointer;">
          <input type="checkbox" name="syndicateAsHeroOnNewsMoreSlugs" value="<%= p.slug %>" <%= post && Array.isArray(post.syndicateAsHeroOnNewsMoreSlugs) && post.syndicateAsHeroOnNewsMoreSlugs.indexOf(p.slug) !== -1 ? 'checked' : '' %>>
          <span><%= p.title %> <span class="nm-inline-mono" style="opacity:0.85">/news-more/<%= p.slug %></span></span>
        </label>
        <% }); %>
      </div>
    </fieldset>
    <% } %>
  </div>

  <div class="form-group">
    <label>
      <input type="checkbox" name="pinned" <%= post && post.pinned ? 'checked' : '' %>> Pin this post to the top
    </label>
  </div>

  <div style="display: flex; gap: 1rem; margin-top: var(--space-lg);">
    <button type="submit" class="btn btn-primary">Save Post</button>
    <a href="/admin/community" class="btn btn-outline">Cancel</a>
  </div>
</form>
