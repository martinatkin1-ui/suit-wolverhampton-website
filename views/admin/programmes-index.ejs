<% layout('admin/admin-layout') -%>

<div class="admin-header">
  <h1>Programme pages</h1>
  <p class="admin-hint">These power the detail pop-ups on the <a href="/timetable" target="_blank" rel="noopener">Timetable</a> page (SMART, RISE, art group, etc.). Edit text and photos — page design stays the same.</p>
</div>

<div class="admin-card">
  <table class="admin-table">
    <thead>
      <tr><th>Programme</th><th>Teaser</th><th></th></tr>
    </thead>
    <tbody>
      <% programmes.forEach(function(p) { %>
      <tr>
        <td><strong><%= p.title %></strong><br><span style="color:var(--text-light);font-size:0.85rem;"><code><%= p.slug %></code></span></td>
        <td style="max-width:320px;color:var(--text-mid);font-size:0.9rem;"><%= p.teaser %></td>
        <td><a href="/admin/programmes/edit/<%= encodeURIComponent(p.slug) %>" class="btn btn-primary" style="padding:0.4rem 0.9rem;font-size:0.88rem;">Edit</a></td>
      </tr>
      <% }); %>
    </tbody>
  </table>
</div>
